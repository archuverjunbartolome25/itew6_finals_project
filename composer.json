{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "archuverjunbartolome25/itew6_finals_project",
    "type": "project",
    "description": "FINALS System - Student Profiling Management System",
    "keywords": ["laravel", "framework", "student-profiling", "management"],
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "backend/app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "backend/tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php -r \"file_exists('backend/.env') || copy('backend/.env.example', 'backend/.env');\""
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('backend/.env') || copy('backend/.env.example', 'backend/.env');\""
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
